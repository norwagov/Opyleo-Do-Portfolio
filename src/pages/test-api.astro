    <CardTemplate
        title = {book.title}
        price = {`${book.price} zł`}
        state = {state[book.condition - 1]}
        seller = {book.creator_name}
        imageUrl = {book.first_image}
    />
    ))} -->

<div id="card" style="display:none;">
  <CardTemplate 
    title={title}
    price={price}
    state={state}
    seller={seller}
    imageUrl={imageUrl}
  />
</div>