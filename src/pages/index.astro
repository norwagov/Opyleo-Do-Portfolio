---
import '../css/global.css';
import '../css/tailwind.css';
import '../css/style.css';
import '../css/animations.css';
import Swiper from '../components/swiperComponent.astro'
import MobileAppPopup from '../components/popup.astro';
import GoogleAnalyticsHead from '../components/googleAnalyticsHead.astro';
import { ClientRouter } from 'astro:transitions';
const basePrefix = import.meta.env.DEV ? 'Opyleo-Landing-Page/' : '';
---


<html lang="Cpl" class="overflow-x-hidden no-scrollbar min-[460px]:overflow-y-hidden">
    <head>
        <GoogleAnalyticsHead />
        <meta charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="icon" type="image/x-icon" href={`${basePrefix}favicon.svg`}>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

        <!-- Preload critical images -->
        <link 
            rel="preload"
            href={`${basePrefix}woman-reading-night.png`}
            as="image"
            fetchpriority="high"
            type="image/png"
        >
        <link 
            rel="preload"
            href={`${basePrefix}man-book.png`}
            as="image"
            fetchpriority="high"
            type="image/png"
        >
        <!-- Lower priority for less critical images -->
        <link
            rel="preload"
            href={`${basePrefix}section-5.png`}
            as="image"
            fetchpriority="high"
            type="image/png"
        >
        <title>Opyleo</title>
        <style>
           
            /* Add loading styles */
            .image-loading {
                position: relative;
                background: linear-gradient(110deg, #ececec 8%, #f5f5f5 18%, #ececec 33%);
                background-size: 200% 100%;
                animation: 1.5s shine linear infinite;
            }

            @keyframes shine {
                to {
                    background-position-x: -200%;
                }
            }

            html {
                scroll-behavior: smooth;
                height: 100%;
                /* Increased scroll-behavior duration for smoother transitions */
                --scroll-behavior: smooth;
                scroll-timeline: --page-scroll block;
            }

            body {
                scroll-snap-type: y mandatory; /* Changed from mandatory to proximity for smoother snapping */
                overflow-y: auto;
                height: 100%;
                overflow-x: hidden;
                /* Add smooth scrolling properties */
                -webkit-overflow-scrolling: touch;
                scroll-behavior: smooth;
            }

            section {
                scroll-snap-align: start;
                scroll-snap-stop: normal; /* Changed from always to normal for smoother transitions */
                min-height: 100svh;
                position: relative;
                /* Add transform properties for smoother rendering */
                transform: translateZ(0);
                -webkit-transform: translateZ(0);
                backface-visibility: hidden;
                -webkit-backface-visibility: hidden;
            }

            /* Add smooth transition for section content */
            section > * {
                transition: opacity 0.3s ease-out;
            }

            /* Optional: Add smooth transition when sections come into view */
            @media (prefers-reduced-motion: no-preference) {
                section {
                    animation: fade-in 0.5s ease-out;
                }
            }

            @keyframes fade-in {
                from {
                    opacity: 0.8;
                }
                to {
                    opacity: 1;
                }
            }

            .vertical-snap-slider {
                touch-action: pan-y;
                -webkit-overflow-scrolling: touch;
            }

            /* Hide scrollbar for Chrome, Safari and Opera */
            .vertical-snap-slider::-webkit-scrollbar {
                display: none;
            }

            /* Hide scrollbar for IE, Edge and Firefox */
            .vertical-snap-slider {
                -ms-overflow-scrolling: touch;
                scrollbar-width: none;
            }
        </style>
        <ClientRouter />
    </head>
    <body class="no-scrollbar overflow-x-hidden min-[460px]:overflow-y-hidden">
        <!-- Overlays section -->
        <!-- Loading overlay -->
        <div id="loading-overlay" class="hidden max-[460px]:flex fixed inset-0 z-[9999] bg-highlight-1 items-center justify-center">
            <div class="text-white text-4xl font-black flex flex-col items-center gap-4">
                <!-- <span class="animate-pulse">opyleo</span> -->
                <div class="loading-dots">
                    <div class="loading-dot"></div>
                    <div class="loading-dot"></div>
                    <div class="loading-dot"></div>
                </div>
            </div>
        </div>
        <!-- Non-mobile overlay -->
        <div class="fixed min-[460px]:flex hidden inset-0 bg-background-4 z-50 flex-col justify-between h-screen">
            <!-- Main content - now with py-8 for some spacing -->
            <div class="w-full p-4 flex justify-end">
            </div>
            <div class="flex-grow flex items-center justify-center">
                <div class="flex flex-col min-[1200px]:items-end max-[1200px]:items-center min-[1200px]:flex-row wx-full justify-center gap-6">
                    <!-- Existing logo and content -->
                    <div class="flex justify-center w-[20rem] max-md:w-[15rem]">
                        <svg class="drop-shadow-2xl animate-slide-in-bounce-svg" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect width="120" height="120" rx="25" fill="var(--highlight-1)"/>
                            <path d="M34.6304 67.152C33.5917 67.152 32.6544 66.9303 31.8184 66.487C30.9951 66.0437 30.3427 65.4103 29.8614 64.587C29.3927 63.7637 29.1584 62.801 29.1584 61.699C29.1584 60.6097 29.3991 59.6533 29.8804 58.83C30.3617 57.994 31.0204 57.3543 31.8564 56.911C32.6924 56.4677 33.6297 56.246 34.6684 56.246C35.7071 56.246 36.6444 56.4677 37.4804 56.911C38.3164 57.3543 38.9751 57.994 39.4564 58.83C39.9377 59.6533 40.1784 60.6097 40.1784 61.699C40.1784 62.7883 39.9314 63.751 39.4374 64.587C38.9561 65.4103 38.2911 66.0437 37.4424 66.487C36.6064 66.9303 35.6691 67.152 34.6304 67.152ZM34.6304 64.34C35.2511 64.34 35.7767 64.112 36.2074 63.656C36.6507 63.2 36.8724 62.5477 36.8724 61.699C36.8724 60.8503 36.6571 60.198 36.2264 59.742C35.8084 59.286 35.2891 59.058 34.6684 59.058C34.0351 59.058 33.5094 59.286 33.0914 59.742C32.6734 60.1853 32.4644 60.8377 32.4644 61.699C32.4644 62.5477 32.6671 63.2 33.0724 63.656C33.4904 64.112 34.0097 64.34 34.6304 64.34ZM44.619 57.899C44.9357 57.405 45.3727 57.006 45.93 56.702C46.4874 56.398 47.1397 56.246 47.887 56.246C48.761 56.246 49.5527 56.4677 50.262 56.911C50.9714 57.3543 51.5287 57.9877 51.934 58.811C52.352 59.6343 52.561 60.5907 52.561 61.68C52.561 62.7693 52.352 63.732 51.934 64.568C51.5287 65.3913 50.9714 66.031 50.262 66.487C49.5527 66.9303 48.761 67.152 47.887 67.152C47.1524 67.152 46.5 67 45.93 66.696C45.3727 66.392 44.9357 65.9993 44.619 65.518V72.054H41.37V56.398H44.619V57.899ZM49.255 61.68C49.255 60.8693 49.027 60.236 48.571 59.78C48.1277 59.3113 47.5767 59.077 46.918 59.077C46.272 59.077 45.721 59.3113 45.265 59.78C44.8217 60.2487 44.6 60.8883 44.6 61.699C44.6 62.5097 44.8217 63.1493 45.265 63.618C45.721 64.0867 46.272 64.321 46.918 64.321C47.564 64.321 48.115 64.0867 48.571 63.618C49.027 63.1367 49.255 62.4907 49.255 61.68ZM64.5636 56.398L57.9135 72.035H54.4175L56.8495 66.639L52.5365 56.398H56.1655L58.6165 63.029L61.0486 56.398H64.5636ZM68.4554 52.94V67H65.2064V52.94H68.4554ZM80.272 61.528C80.272 61.83