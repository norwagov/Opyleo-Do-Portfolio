                        </svg>
                    </div>
                    <div class="flex flex-col gap-10">
                        <div class="flex flex-col">
                            <p class="text-2xl min-[360px]:!text-3xl text-center font-bold text-white animate-slide-in-bounce-text">
                                Pełną parą pracujemy nad stronką dla ciebie!
                            </p>
                            <p class="text-lg min-[360px]:!text-xl text-center font-bold text-white mt-6 animate-slide-in-bounce-text delay-200">
                                Czemu nie rzucisz okiem na naszą apkę w międzyczasie?
                            </p>
                        </div>
                        <div class="flex justify-center flex-row gap-4 mb-4 font-bold animate-fadeIn delay-500">
                            <a
                                href="https://apps.apple.com/pl/app/opyleo/id6504999106"
                                class="shadow-[0_0_15px_rgba(0,0,0,0.3)] bg-black text-white px-6 py-3 rounded-lg flex items-center justify-center space-x-2 hover:bg-gray-800 transition-all duration-300"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                                <svg fill="none" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="m5.47437 20.299-.60228.9418c-.4231.726-1.36015.9747-2.09299.5556-.73272-.4192-.98393-1.3475-.56083-2.0735l.38218-.5577c.14634-.2083.50746-.568 1.22985-.5003 0 0 1.69995.1827 1.82298 1.058 0 0 .01668.288-.17891.5761zm16.99343-6.1278h-3.6144c-.2462-.0164-.3536-.1035-.396-.1542l-.0026-.0046-3.4548-5.60064c-.3803-.57618-.9842.89735-.9842.89735-.7211 1.64199.1024 3.50869.3893 4.07299l4.7228 7.8567c.423.7259 1.36.9748 2.093.5555.7327-.4192.9839-1.3475.5607-2.0735l-1.3437-2.3058c-.0261-.0559-.0714-.2075.2042-.2082h1.8257c.8462 0 1.5322-.6796 1.5322-1.5179s-.686-1.5177-1.5322-1.5177zm-8.7039 2.0635s.1929.9722-.5536.9722l-11.67813-.0001c-.846202 0-1.53217-.6796-1.53217-1.5179s.685968-1.5178 1.53217-1.5178h3.43514c.5546-.0318.68597-.349.68597-.349l.00317.0016 4.48395-7.69411-.0013-.00026c.0817-.14864.0136-.28914.0018-.31131l-1.48089-2.54104c-.4231-.72587-.17202-1.65431.56083-2.07333.73285-.419157 1.66986-.17055 2.09296.55546l.6868 1.17848.6856-1.17638c.4231-.72588 1.3601-.974749 2.093-.55546.7328.41915.9839 1.34732.5608 2.07333l-6.23967 10.70652c-.02728.0652-.03562.1675.16739.1855l2.04608.0001s2.1565.0693 2.4501 2.0635z" fill="#FFF"/></svg>
                                <span>App Store</span>
                            </a>

                            <a
                                href="https://play.google.com/store/apps/details?id=com.opyleo&pcampaignid=web_share"
                                class="shadow-[0_0_20px_rgba(34,197,94,0.4)] bg-green-500 text-white px-6 py-3 rounded-lg flex items-center justify-center space-x-2 hover:bg-green-600 transition-all duration-300"
                            >
                            <svg xmlns="http://www.w3.org/2000/svg" fill="#FFF" x="0px" y="0px" width="30" height="30" viewBox="0 0 50 50">
                            <path d="M 7.125 2 L 28.78125 23.5 L 34.71875 17.5625 L 8.46875 2.40625 C 8.03125 2.152344 7.5625 2.011719 7.125 2 Z M 5.3125 3 C 5.117188 3.347656 5 3.757813 5 4.21875 L 5 46 C 5 46.335938 5.070313 46.636719 5.1875 46.90625 L 27.34375 24.90625 Z M 36.53125 18.59375 L 30.1875 24.90625 L 36.53125 31.1875 L 44.28125 26.75 C 45.382813 26.113281 45.539063 25.304688 45.53125 24.875 C 45.519531 24.164063 45.070313 23.5 44.3125 23.09375 C 43.652344 22.738281 38.75 19.882813 36.53125 18.59375 Z M 28.78125 26.3125 L 6.9375 47.96875 C 7.300781 47.949219 7.695313 47.871094 8.0625 47.65625 C 8.917969 47.160156 26.21875 37.15625 26.21875 37.15625 L 34.75 32.25 Z"></path>
                            </svg>
                                <span>Google Play</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Footer links with fixed height -->
            <div class="w-full p-4 flex justify-end">
                <div class="flex gap-4 text-sm">
                    <a href={`${basePrefix}polityka-prywatnosci`} class="text-white hover:text-highlight-1 transition-colors">
                        Polityka prywatności
                    </a>
                    <a href={`${basePrefix}regulamin`} class="text-white hover:text-highlight-1 transition-colors">
                        Regulamin
                    </a>
                </div>
            </div>
        </div>
        <div class="vertical-snap-slider h-[100svh] overflow-y-scroll snap-y snap-mandatory relative">
            <!-- Section 1 -->
            <section class="snap-section !snap-start !snap-always h-[100svh] w-full relative overflow-hidden" data-section="1">
                <section 
                    style="background: linear-gradient(110deg, #D76F9F 0%, #FFFFFF 100%);" 
                    class="h-[100svh]">
                    <header class="shadow-xl h-[10lvh] bg-highlight-1 flex flex-row justify-center items-center text-white font-poppins font-bold text-2xl p-6">
                        <h1>opyleo</h1>
                        <div class="flex-grow"></div>
                        <button id="header-download-app-button" class="bg-highlight-3 text-sm text-white py-2 px-4 rounded-lg inline-flex items-center justify-around">
                            <svg class="""fill-current w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M13 8V2H7v6H2l8 8 8-8h-5zM0 18h20v2H0v-2z"/></svg>
                            <span>Pobierz</span>
                        </button>
                        <MobileAppPopup triggerSelector="#header-download-app-button" />
                    </header>
                    <div class="h-[90svh] flex flex-col">
                        <!-- Header section with responsive text size -->
                        <div class="grow max-h-[30%] flex items-center justify-center">
                            <div class="scroll-wrapper"> <!-- Consolidate css later -->
                                <div class="scroll-animate-heading text-2xl min-[360px]:text-3xl">
                                    <span>Witaj w <b class="font-black">Opyleo</b></span>
                                    <span><b class="font-black">5 tysięcy</b> użytkowników</span>
                                    <span>Ponad <b class="font-black">10 tysięcy</b> pobrań</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Swiper section -->
                        <div class="grow min-h-0">
                            <Swiper />
                        </div>
                    </div>
                </section>
            </section>

            <!-- Section 2 -->
            <section class="snap-section  !snap-start !snap-always h-[100svh] w-full relative overflow-hidden" data-section="2">
                <section
                    style="background: linear-gradient(-110deg, #FFFFFF 0%, #D76F9F 100%);"
                    class="relative z-0 h-[100lvh] flex justify-center items-center font-bold">
                    <div class="relative z-0">
                        <!-- Blurred background - Load first -->
                        <div class="absolute inset-0">
                            <img
                                style="-webkit-transform: scaleX(-1); transform: scaleX(-1);"
                                src="/Opyleo-Landing-Page/woman-reading-night.png"
                                alt="Background Image"
                                class="blur-3xl h-[100lvh] w-[100vw] object-cover object-center"
                                loading="eager"
                                fetchpriority="high"
                                decoding="async"
                            >
                        </div>
                        <!-- Sharp image - Load after blur -->
                        <div class="relative z-10">
                            <img
                                style="-webkit-transform: scaleX(-1); transform: scaleX(-1);"
                                src="/Opyleo-Landing-Page/woman-reading-night.png"
                                alt="Main Image"
                                class="h-[100lvh] w-[100vw] object-cover object-center opacity-0 transition-opacity duration-300"
                                onload="this.classList.remove('opacity-0')"
                                loading="eager"
                                fetchpriority="high"
                            >
                        </div>
                    </div>
                    <div class="z-10 absolute w-screen overflow-hidden">
                        <div>
                            <div class="relative h-screen">
                                <div class="absolute bottom-0 right-0 h-[150vw] w-[150vw] bg-white/40 backdrop-blur-2xl translate-x-[40%] translate-y-[30%] rounded-full">
                                    <p class="text-right font-bold text-xl min-[360px]:!text-2xl translate-x-[-42%] translate-y-[150%]">
                                        Opyleo,<br>
                                        ekologiczniej się nie da!<br>
                                    </p>
                                    <div class="text-right text-xl min-[360px]:!text-2xl font-extralight translate-x-[-42%] translate-y-[80%]">
                                        Lorem ipsum dolor sit amet,<br>
                                        consectetur adipiscing elit.<br>
                                        Aenean elementum<br>
                                        lacus a purus eleifend convallis.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </section>

            <!-- Section 3 -->
            <section class="snap-section  !snap-start !snap-always h-[100svh] w-full relative overflow-hidden" data-section="3">
                <section
                    style="background: linear-gradient(110deg, #D76F9F 0%, #FFFFFF 100%);"
                    class="relative z-0 h-screen flex flex-col items-center font-bold">
                    <div class="relative m-4 min-[360px]:m-8">
                        <p class="text-3xl min-[360px]:!text-4xl font-bold mb-2 min-[360px]:mb-4">Opyleo</p>
                        <p class="text-lg min-[360px]:!text-xl font-normal">Odkryj nasze kategorie i sprawdź, która najbardziej Ci się podoba!</p>
                    </div>
                    <div id="bubbles-container" class="relative flex-grow w-full"></div>
                    <div class="h-[10%] w-full"></div>
                </section>
            </section>

            <!-- Section 4 -->
            <section class="snap-section  !snap-start !snap-always h-[100svh] w-full relative overflow-hidden" data-section="4">
                <section
                    style="background: linear-gradient(-110deg, #FFFFFF 0%, #D76F9F 100%);"
                    class="relative z-0 h-[100lvh] flex justify-center items-center font-bold">
                    <div class="transform scale-x-[-1] relative z-0">
                        <div>
                            <img
                                style="-webkit-transform: scaleX(-1); transform: scaleX(-1);"
                                src="/Opyleo-Landing-Page/man-book.png"
                                alt="Image"
                                class="blur-3xl h-[100lvh] w-[100vw] object-cover object-center"
                                loading="eager"
                                fetchpriority="high"
                            >
                        </div>
                        <div class="z-10 absolute top-0 left-0">
                            <img
                                style="-webkit-transform: scaleX(-1); transform: scaleX(-1);"
                                src="/Opyleo-Landing-Page/man-book.png"
                                alt="Image"
                                class="h-[100lvh] w-[100vw] object-cover object-center"
                                loading="eager"
                                fetchpriority="high"
                            >
                        </div>
                    </div>
                    <div class="z-10 absolute w-screen overflow-hidden">
                        <div>
                            <div class="relative h-screen">
                                <div class="absolute bottom-0 right-0 h-[150vw] w-[150vw] bg-white/40 backdrop-blur-2xl translate-x-[-8%] translate-y-[30%] rounded-full">
                                    <p class="text-left font-bold text-xl min-[360px]:!text-2xl translate-x-[44%] translate-y-[150%]">
                                        Wrzuć zdjęcie,<br>
                                        a resztę zostaw nam!<br>
                                    </p>
                                    <div class="text-left text-xl min-[360px]:!text-2xl font-extralight translate-x-[44%] translate-y-[80%]">
                                        Lorem ipsum dolor sit amet,<br>
                                        consectetur adipiscing elit.<br>
                                        Aenean elementum<br>
                                        lacus a purus eleifend convallis.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </section>

            <!-- Section 5 (Last section) - Update this section -->
            <section class="snap-section  !snap-start !snap-always h-[100svh] w-full relative overflow-hidden" data-section="5">
                <section class="relative h-[100svh] w-full flex flex-col items-center font-bold">
                    <div class="absolute top-0 w-full h-full z-10">
                        <div
                            style="
                                background: linear-gradient(110deg, #D76F9F 0%, #FFFFFF 100%);;
                                -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 30%, rgba(0, 0, 0, 0) 100%);
                                mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 30%, rgba(0, 0, 0, 0) 100%);"
                            class="w-full h-full"
                        ></div>
                    </div>
