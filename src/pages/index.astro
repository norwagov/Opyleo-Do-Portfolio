        <!-- Progress indicator -->
        <div id="progress-indicator"  class="flex min-[460px]:!hidden fixed right-[10px] top-1/2 translate-y-[-50%] gap-[8px] z-[1000] flex-col transform-opacity duration-300">
            <div class="progress-dot w-2 h-2 rounded-full bg-white/50 transition-all duration-300 ease-in-out group-active:bg-white group-active:scale-150" data-section="1"></div>
            <div class="progress-dot w-2 h-2 rounded-full bg-white/50 transition-all duration-300 ease-in-out group-active:bg-white group-active:scale-150" data-section="2"></div>
            <div class="progress-dot w-2 h-2 rounded-full bg-white/50 transition-all duration-300 ease-in-out group-active:bg-white group-active:scale-150" data-section="3"></div>
            <div class="progress-dot w-2 h-2 rounded-full bg-white/50 transition-all duration-300 ease-in-out group-active:bg-white group-active:scale-150" data-section="4"></div>
