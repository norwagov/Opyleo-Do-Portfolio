        <script src="../js/correctHeights.ts"></script>
        <script src="../js/scrollButton.ts"></script>
        <script src="../js/loadingOverlay.js"></script>
        <script>
            // Bubbles init script
            
            import { BubbleLayout, type Genre } from '../js/bubbles';

            document.addEventListener('DOMContentLoaded', function() {
            const genres: Genre[] = [
                { name: 'Horrory', popularity: 0.8 },
                { name: 'Romansy', popularity: 1.0 },
                { name: 'Fantastyka', popularity: 0.9 },
                { name: 'Kryminały', popularity: 1.0 },
                { name: 'Przygodowe', popularity: 0.85 },
                { name: 'Podręczniki', popularity: 0.8 },
                { name: 'Zbiory zadań', popularity: 0.7},
                { name: 'Psychologia', popularity: 0.65}
            ];

            try {
                const layout = new BubbleLayout('bubbles-container', genres);

                // Cleanup on page unload
                window.addEventListener('unload', () => {
                layout.destroy();
                });
            } catch (error) {
                console.error('Failed to initialize bubble layout:', error);
            }
            });

            document.addEventListener('DOMContentLoaded', () => {
                const slider = document.querySelector('.vertical-snap-slider');
                const sections = document.querySelectorAll('.snap-section');
                const dots: any = document.querySelectorAll('.progress-dot');
                let isScrolling = false;
                let currentSection = 1;

                // Update active section based on scroll position
                const updateActiveSection = () => {
                    sections.forEach((section, index) => {
                        const rect = section.getBoundingClientRect();
                        if (rect.top >= 0 && rect.top < window.innerHeight / 2) {
                            currentSection = index + 1;
                        }
                    });

                    dots.forEach((dot: Element) => {
                        dot.classList.remove('active');
                        if (parseInt(dot.getAttribute('data-section') || '0') === currentSection) {
                            dot.classList.add('active');
                        }
                    });
                };

                if (slider) {
                    slider.addEventListener('scroll', () => {
                        if (!isScrolling) {
                            window.requestAnimationFrame(() => {
                                updateActiveSection();
                                isScrolling = false;
                            });
                            isScrolling = true;
                        }
                    });
                }
                //  Initial update
                updateActiveSection();
            });
        </script>
    </body>
</html>

