---
import '../css/card.css'
import 'swiper/css';
import 'swiper/css/autoplay';
import CardTemplate from './cardTemplate.astro';
import MobileAppPopup from '../components/popup.astro';
import type Popup from './popup.astro';
---

<div class="w-screen container-type-swiper" id="swiper-wrapper">
  <MobileAppPopup triggerSelector="#swiper-wrapper" />
  <div class="swiper overflow-visible h-full">
    <div class="swiper-wrapper" id="swiper-wrapper-container">
    </div>
  </div>
</div>

<style>
  ::-webkit-scrollbar {
    display: none;
  }
  .swiper-slide {
    display: unset;
  }
  body {
    overscroll-behavior: none;
  }
  /* .container-type-swiper {
    container-type: size;
    container-name: swiper;
  } */
</style>

<script>
  const basePrefix: string = import.meta.env.DEV ? 'Opyleo-Landing-Page/' : '';
  const api_url: string = import.meta.env.PUBLIC_API_URL;
  
  import Swiper from 'swiper';
  import { Autoplay } from 'swiper/modules';

  interface Book {
    title: string;
    price: number;
    condition: number;
    creator_name: string;
    first_image: string;
  }

  function measureTextWidth(text: string, font: string): number {
    const canvas = document.createElement('canvas');
    const context = canvas.getContext('2d');
    if (context) {
      context.font = font;
      return context.measureText(text).width;
    }
    return 0;
  }

  function truncateToFit(
    title: string, 
    maxWidth: number, 
    font: string, 
    allowTwoLines: boolean = false
  ): string {
    const cleanTitle = title.trim().replace(/\s+/g, ' ');
    const words: string[] = cleanTitle.split(' ').filter(word => word.length > 0);
    const ellipsis: string = '...';
  
    
    // Early return if text fits completely
    if (measureTextWidth(title, font) <= maxWidth) {
      return title;
    }

    if (allowTwoLines) {
      let firstLine: string[] = [];
      let secondLine: string[] = [];
      let currentFirstLine = '';
      let currentSecondLine = '';

      // Process first line
      for (let i = 0; i < words.length; i++) {
        const testLine = currentFirstLine + (currentFirstLine ? ' ' : '') + words[i];
        if (measureTextWidth(testLine, font) <= maxWidth) {
          currentFirstLine = testLine;
          firstLine.push(words[i]);
        } else {
          // Start second line
          const remainingWords = words.slice(i);
          currentSecondLine = remainingWords.join(' ');
          
          // If second line fits completely
          if (measureTextWidth(currentSecondLine, font) <= maxWidth) {
            secondLine = remainingWords;
            break;
          }
          
          // Truncate second line
          for (let j = 0; j < remainingWords.length; j++) {
            const testSecondLine = remainingWords.slice(0, j + 1).join(' ');
            const withEllipsis = testSecondLine + ellipsis;
            
            if (measureTextWidth(withEllipsis, font) > maxWidth) {
              secondLine = remainingWords.slice(0, j);
              break;
            }
          }
          break;
        }
      }

      if (secondLine.length > 0) {
        const needsEllipsis = words.length > (firstLine.length + secondLine.length);
        return `${firstLine.join(' ')}\n${secondLine.join(' ')}${needsEllipsis ? ellipsis : ''}`;
      }
    }

    // Single line truncation - more precise approach
    let result = '';
    let currentLine = '';
    
    for (let i = 0; i < words.length; i++) {
      const testLine = currentLine + (currentLine ? ' ' : '') + words[i];
      const withEllipsis = testLine + ellipsis;
      console.log(testLine);
      if (measureTextWidth(withEllipsis, font) <= maxWidth) {
        currentLine = testLine;
        result = testLine;
      } else {
        break;
      }
    }

    // Only add ellipsis if we actually truncated the text
    const needsEllipsis = result.length < title.length;
    return result + (needsEllipsis ? ellipsis : '');
  }

  function initializeTitleTruncation(): void {
    const titleElements: NodeListOf<HTMLElement> = document.querySelectorAll('.title-responsive');
    
    titleElements.forEach(element => {
      const titleEl: HTMLElement = element;
      // Clean up the original text
      const originalText: string = (
        titleEl.getAttribute('data-original-title') || 
        titleEl.textContent || ''
      ).trim().replace(/\s+/g, ' ');
      
      // Store clean original text
      titleEl.setAttribute('data-original-title', originalText);
      
      const computedStyle: CSSStyleDeclaration = window.getComputedStyle(titleEl);
      const availableWidth: number = titleEl.clientWidth;
      const font: string = `${computedStyle.fontWeight} ${computedStyle.fontSize} ${computedStyle.fontFamily}`;
      
      const allowTwoLines: boolean = window.innerHeight < 600;
      
      const truncatedText: string = truncateToFit(originalText, availableWidth, font, allowTwoLines);
      titleEl.textContent = truncatedText; // This will be clean by default since we cleaned the input
      
      if (allowTwoLines) {
        titleEl.style.whiteSpace = 'pre-line';
        titleEl.style.lineHeight = '1.2';
      }
    });
  }

  const swiper: Swiper = new Swiper('.swiper', {
    modules: [Autoplay], 
    slidesPerView: 1.5,
    loop: true,
    centeredSlides: true,
    spaceBetween: 30,
    allowTouchMove: false,
    effect: 'slide',
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true
    },
    speed: 1000,
  });

  const loadBooks = async (): Promise<void> => {
    try {
      const page: number = Math.floor(Math.random() * 10 + 1);
      const response: Response = await fetch(`${api_url}?page=${page}`);
      if (!response.ok) throw new Error(`HTTP error! Status: ${response.status}`);
      
      const data = await response.json();
      const books: Book[] = data.results || [];

      const booksContainer: HTMLElement | null = document.getElementById('swiper-wrapper-container');

      if (booksContainer && books.length > 0) {
        books.forEach((book: Book) => {
          const slideElement: HTMLDivElement = document.createElement('div');
          slideElement.className = 'swiper-slide !flex items-center';
          slideElement.innerHTML = `
            <div class="w-full max-w-18 bg-white rounded-xl transition-shadow aspect-responsive" data-truncated="false" data-original-title="${book.title.trim().replace(/\s+/g, ' ')}}">
              <div class="relative w-full h-2/3">
                <div class="w-full h-full rounded-t-xl overflow-hidden">
                  <img draggable="false"
                      class="w-full h-full object-cover"
                      src="${book.first_image}"
                      alt="${book.title}"
                      onerror="this.onerror=null; this.src='${basePrefix}default-image.jpg';">
                </div>
                <button class="absolute top-3 right-3 bg-black/40 hover:bg-black/60 rounded-full p-2.5 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </button>
              </div>

              <div class="p-4 flex flex-col justify-start h-1/3 details-container">
                <div class="flex flex-col gap-1 description-small">
                  <h2 class="text-base max-[370px]:text-sm md:text-lg lg:text-xl font-medium title-responsive">
                    ${book.title}
                  </h2>
                  <p class="text-lg md:text-xl max-[370px]:text-base lg:text-2xl font-bold price-responsive">
                    ${book.price} zł
                  </p>
                  <p class="text-gray-600 max-[370px]:text-sm text-sm hide-on-small hide-on-medium state-hidden">
                    ${state[book.condition - 1]}
                  </p>
                </div>
                
                <div class="flex items-center justify-between mt-auto hide-on-small">
                  <div class="flex items-center gap-2 compact-on-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <span class="text-xs md:text-sm text-gray-600">${book.creator_name}</span>
                  </div>
                  <button class="p-1 hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-gray-400 hover:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          `;
          booksContainer.appendChild(slideElement);
        });

        setTimeout(initializeTitleTruncation, 100);
      }
    } catch (error) {
      console.error("Error loading books: ", error);
    }
  };

  const state: string[] = ["Zły", "Umiarkowany", "Dobry", "Bardzo dobry"];

  document.addEventListener("DOMContentLoaded", () => {
    loadBooks();
    window.addEventListener('load', initializeTitleTruncation);
  });

  document.addEventListener('astro:before-swap', () => {
    window.addEventListener('load', initializeTitleTruncation);
  });
</script>
