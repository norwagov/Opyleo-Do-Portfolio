---
// cardTemplate.astro

interface Props {
    title?: string;
    price?: string;
    state?: string;
    seller?: string;
    defaultImagePath?: string;
    imageUrl?: string;
}

const { 
    title = "Tytuł", 
    price = "Cena", 
    state = "Stan", 
    seller = "Imię Nazwisko",
    defaultImagePath = "default-image.jpg",
    imageUrl = ""
} = Astro.props;
---
<style>
    /* Default aspect ratio */
    .aspect-responsive {
        aspect-ratio: 7/12;
    }

    /* Large devices (tablets and larger) */
    @media (min-height: 700px) {
        .aspect-responsive {
            aspect-ratio: 7/12;
        }
    }

    /* Medium devices (larger phones) */
    @media (min-height: 600px) and (max-height: 699px) {
        .aspect-responsive {
            aspect-ratio: 2/3;
        }
        .price-responsive {
            @apply text-base;
        }
        .title-responsive {
            @apply text-sm;
        }
        .hide-on-medium {
            display: none;
        }
    }

    /* Small devices (iPhone SE and similar) */
    /* @media (max-height: 599px) {
        .aspect-responsive {
            aspect-ratio: 5/7;
        }
        .details-container {
            @apply py-1;
        }
        .hide-on-small {
            display: none;
        }
        .description-small {
            @apply h-full justify-around;
        }
        .price-responsive {
            @apply text-sm;
        }
        .title-responsive {
            @apply text-sm;
        }
    } */
</style>
<!-- <div class="w-full max-w-18 bg-white rounded-xl transition-shadow aspect-responsive">
    <div class="relative w-full h-2/3"> {/* Maintain proportional height */}
        <div class="w-full h-full rounded-t-xl overflow-hidden">
            <img draggable="false"
                class="w-full h-full object-cover"
                src={imageUrl}
                alt={title}
                onerror=`this.onerror=null; this.src='${defaultImagePath}';`> -->
<div class="w-[280px] bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow">
    <!-- Image Container -->
    <div class="relative">
        <!-- Main Image Area -->
        <div class="h-[360px] rounded-t-xl overflow-hidden">
            <!-- Book cover/content area -->
            <div class="w-full h-full relative">
                <img draggable="false"
                    class="w-full h-full object-cover"
                    src={imageUrl}
                    alt={title}>
                    <!-- onerror=`this.onerror=null; this.src='${defaultImagePath}';` -->
            </div>
        </div>
        <!-- Camera Icon Button -->
        <button class="absolute top-3 right-3 bg-black/40 hover:bg-black/60 rounded-full p-2.5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </button>
    </div>

    <!-- Product Details - Modified for better space usage -->
    <div class="p-4 flex flex-col justify-start h-1/3 details-container">
        <div class="flex flex-col gap-1 description-small">
            <h2 class="text-base max-[370px]:text-sm md:text-lg lg:text-xl font-medium title-responsive">
                {title}
            </h2>
            <p class="text-lg md:text-xl max-[370px]:text-base lg:text-2xl font-bold price-responsive">
                {price}
            </p>
            <!-- State info with conditional visibility -->
            <p class="text-gray-600 max-[370px]:text-sm text-sm hide-on-small hide-on-medium state-hidden">
                {state}
            </p>
        </div>
        
        <!-- Bottom Row with conditional visibility -->
        <div class="flex items-center justify-between mt-auto hide-on-small">
            <!-- User Info -->
            <div class="flex items-center gap-2 compact-on-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="text-xs md:text-sm text-gray-600">{seller}</span>
            </div>
            <!-- Heart Icon -->
            <button class="p-1 hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-gray-400 hover:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
            </button>
        </div>
    </div>
</div>
<script>
function measureTextWidth(text: string, font: string): number {
    const canvas = document.createElement('canvas');
    const context = canvas.getContext('2d');
    if (context) {
        context.font = font;
        return context.measureText(text).width;
    }
    return 0;
}

function truncateToFit(
    title: string,
    maxWidth: number,
    font: string,
    allowTwoLines: boolean = false
): string {
    const words = title.split(' ');
    const ellipsis = '...';
    
    if (allowTwoLines) {
        // Try to fit in two lines
        const firstLine: string[] = [];
        const secondLine: string[] = [];
        let firstLineWidth = 0;
        let secondLineWidth = 0;
        
        // Process words
        for (const word of words) {
            const wordWidth = measureTextWidth(word + ' ', font);
            
            if (firstLineWidth + wordWidth <= maxWidth) {
                firstLine.push(word);
                firstLineWidth += wordWidth;
            } else if (secondLineWidth + wordWidth <= maxWidth) {
                secondLine.push(word);
                secondLineWidth += wordWidth;
            } else {
                // Won't fit in two lines
                if (secondLine.length > 0) {
                    secondLine.pop();
                }
                break;
            }
        }
        
        if (secondLine.length > 0) {
            return `${firstLine.join(' ')}\n${secondLine.join(' ')}${ellipsis}`;
        }
    }
    
    // Fall back to single line truncation
    let currentText = words.join(' ') + ellipsis;
    let currentWidth = measureTextWidth(currentText, font);
    
    while (words.length > 0 && currentWidth > maxWidth) {
        words.pop();
        currentText = words.join(' ') + ellipsis;
        currentWidth = measureTextWidth(currentText, font);
    }
    
    return words.join(' ') + ellipsis;
}

function initializeTitleTruncation() {
    const titleElements = document.querySelectorAll('.title-responsive');
    
    titleElements.forEach(element => {
        // Check if element was already processed
        if (element.hasAttribute('data-truncated')) return;

        const titleEl = element as HTMLElement;
        const originalText = titleEl.getAttribute('data-original-title') || titleEl.textContent || '';
        const computedStyle = window.getComputedStyle(titleEl);
        const availableWidth = titleEl.clientWidth;
        const font = `${computedStyle.fontWeight} ${computedStyle.fontSize} ${computedStyle.fontFamily}`;
        
        const allowTwoLines = window.innerHeight < 600;
        
        const truncatedText = truncateToFit(originalText, availableWidth, font, allowTwoLines);
        titleEl.textContent = truncatedText;
        
        if (allowTwoLines) {
            titleEl.style.whiteSpace = 'pre-line';
            titleEl.style.lineHeight = '1.2';
        }

        // Mark as processed
        titleEl.setAttribute('data-truncated', 'true');
    });
}

// Run only on load, remove resize listener
window.addEventListener('load', initializeTitleTruncation);
</script>